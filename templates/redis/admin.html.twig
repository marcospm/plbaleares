{% extends 'base.html.twig' %}

{% block title %}Administración de Caché Redis{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Administración de Caché Redis</h1>
            
            {% if action_result %}
                <div class="alert alert-{{ action_result.success ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
                    {{ action_result.message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endif %}
            
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Estado del Caché</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Usando Redis:</strong> 
                                <span class="badge bg-{{ stats.using_redis ? 'success' : 'warning' }}">
                                    {{ stats.using_redis ? 'Sí' : 'No (Filesystem)' }}
                                </span>
                            </p>
                            <p><strong>Adaptador:</strong> {{ stats.adapter_class }}</p>
                        </div>
                        <div class="col-md-6">
                            {% if stats.memory %}
                                <p><strong>Memoria usada:</strong> {{ stats.memory }}</p>
                            {% endif %}
                            {% if stats.keys_count is not null %}
                                <p><strong>Claves en caché:</strong> 
                                    {% if stats.keys_count is same as('N/A') %}
                                        {{ stats.keys_count }}
                                    {% else %}
                                        {{ stats.keys_count|number_format(0, ',', '.') }}
                                        {% if stats.total_keys_estimated and stats.total_keys_estimated != stats.keys_count %}
                                            (estimado: {{ stats.total_keys_estimated|number_format(0, ',', '.') }})
                                        {% endif %}
                                    {% endif %}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Pools de Caché</h5>
                </div>
                <div class="card-body">
                    {% if stats.cache_pools|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th>Pool</th>
                                        <th>Descripción</th>
                                        <th>Adaptador</th>
                                        <th>Estado</th>
                                        <th>Claves</th>
                                        <th style="min-width: 200px;">Disponible / Error</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for pool in stats.cache_pools %}
                                        <tr>
                                            <td><code>{{ pool.name }}</code></td>
                                            <td>{{ pool.label }}</td>
                                            <td>
                                                {% if pool.adapter_class != 'N/A' %}
                                                    <small class="text-muted">{{ pool.adapter_class|split('\\')|last }}</small>
                                                {% else %}
                                                    <span class="text-muted">N/A</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if pool.available %}
                                                    <span class="badge bg-{{ pool.is_redis ? 'success' : 'secondary' }}">
                                                        {{ pool.is_redis ? 'Redis' : 'Filesystem' }}
                                                    </span>
                                                {% else %}
                                                    <span class="badge bg-warning">No disponible</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if pool.keys_count is defined %}
                                                    {% if pool.keys_count is same as('N/A') %}
                                                        <span class="text-muted">N/A</span>
                                                    {% else %}
                                                        {{ pool.keys_count|number_format(0, ',', '.') }}
                                                    {% endif %}
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if pool.available %}
                                                    <span class="badge bg-success">Sí</span>
                                                {% else %}
                                                    <span class="badge bg-danger">No</span>
                                                    {% if pool.error %}
                                                        <div class="mt-2">
                                                            <small class="text-danger d-block" style="word-break: break-word;">
                                                                <strong>Error:</strong> {{ pool.error }}
                                                            </small>
                                                        </div>
                                                    {% endif %}
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="alert alert-warning">
                            <p class="mb-0">No se encontraron pools de caché configurados.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
            
            {% if stats.sample_keys|length > 0 %}
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Claves de Ejemplo (primeras 20)</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Clave</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for key in stats.sample_keys %}
                                        <tr>
                                            <td><code>{{ key }}</code></td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% endif %}
            
            {% if stats.info %}
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Información Detallada de Redis</h5>
                    </div>
                    <div class="card-body">
                        <div class="accordion" id="redisInfoAccordion">
                            {% for section, data in stats.info %}
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="heading{{ loop.index }}">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ loop.index }}" aria-expanded="false" aria-controls="collapse{{ loop.index }}">
                                            {{ section|capitalize }}
                                        </button>
                                    </h2>
                                    <div id="collapse{{ loop.index }}" class="accordion-collapse collapse" aria-labelledby="heading{{ loop.index }}" data-bs-parent="#redisInfoAccordion">
                                        <div class="accordion-body">
                                            {% if data is iterable %}
                                                <table class="table table-sm">
                                                    <tbody>
                                                        {% for key, value in data %}
                                                            <tr>
                                                                <td><strong>{{ key }}</strong></td>
                                                                <td>{{ value }}</td>
                                                            </tr>
                                                        {% endfor %}
                                                    </tbody>
                                                </table>
                                            {% else %}
                                                <pre>{{ data }}</pre>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endif %}
            
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Acciones</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ path('app_redis_admin') }}" onsubmit="return confirm('¿Estás seguro de que quieres limpiar todo el caché? Esta acción no se puede deshacer.');">
                        <input type="hidden" name="action" value="clear">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Limpiar Todo el Caché
                        </button>
                        <small class="text-muted d-block mt-2">
                            Esto eliminará todas las claves del caché. El caché se regenerará automáticamente cuando se necesite.
                        </small>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
