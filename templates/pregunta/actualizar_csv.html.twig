{% extends 'base.html.twig' %}

{% block title %}Actualizar Preguntas CSV{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .file-upload-area {
            border: 2px dashed #ddd;
            border-radius: 8px;
            padding: 2rem;
            text-align: center;
            background: #f8f9fa;
            transition: all 0.3s;
        }
        
        .file-upload-area:hover {
            border-color: var(--color-warning);
            background: #fff3cd;
        }
        
        .file-upload-area.dragover {
            border-color: var(--color-warning);
            background: #fff3cd;
        }
    </style>
{% endblock %}

{% block body %}
<div class="card">
    <div class="card-header">
        <h1>Actualizar Preguntas CSV</h1>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <strong>Instrucciones:</strong>
            <ul class="mb-0">
                <li>Sube un archivo CSV con las preguntas que deseas actualizar.</li>
                <li>El CSV debe contener todas las columnas: <strong>id, texto, opcion_a, opcion_b, opcion_c, opcion_d, respuesta_correcta, retroalimentacion, tema_id, ley_id, articulo_id, dificultad</strong></li>
                <li>El <strong>ID</strong> es obligatorio y debe corresponder a una pregunta existente.</li>
                <li>Puedes descargar un CSV desde "Descargar Preguntas del Tema" para obtener el formato correcto.</li>
                <li>La respuesta correcta debe ser A, B, C o D.</li>
                <li>La retroalimentación es opcional.</li>
            </ul>
        </div>

        <form method="post" action="{{ path('app_pregunta_procesar_actualizar_csv') }}" enctype="multipart/form-data" id="csv-form">
            <div class="mb-3">
                <label class="form-label">Archivo CSV <span class="text-danger">*</span></label>
                <div class="file-upload-area" id="file-upload-area">
                    <input type="file" name="archivo_csv" id="archivo_csv" accept=".csv" required style="display: none;">
                    <p class="mb-2">
                        <strong>Haz clic aquí para seleccionar un archivo CSV</strong>
                    </p>
                    <p class="text-muted mb-0" id="file-name">Ningún archivo seleccionado</p>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning">Procesar CSV</button>
                <a href="{{ path('app_pregunta_index') }}" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Manejo de archivo
    const fileUploadArea = document.getElementById('file-upload-area');
    const fileInput = document.getElementById('archivo_csv');
    const fileName = document.getElementById('file-name');

    fileUploadArea.addEventListener('click', () => {
        fileInput.click();
    });

    fileInput.addEventListener('change', (e) => {
        if (e.target.files.length > 0) {
            fileName.textContent = e.target.files[0].name;
            fileUploadArea.style.borderColor = '#ffc107';
        } else {
            fileName.textContent = 'Ningún archivo seleccionado';
            fileUploadArea.style.borderColor = '#ddd';
        }
    });

    fileUploadArea.addEventListener('dragover', (e) => {
        e.preventDefault();
        fileUploadArea.classList.add('dragover');
    });

    fileUploadArea.addEventListener('dragleave', () => {
        fileUploadArea.classList.remove('dragover');
    });

    fileUploadArea.addEventListener('drop', (e) => {
        e.preventDefault();
        fileUploadArea.classList.remove('dragover');
        
        if (e.dataTransfer.files.length > 0) {
            fileInput.files = e.dataTransfer.files;
            fileName.textContent = e.dataTransfer.files[0].name;
            fileUploadArea.style.borderColor = '#ffc107';
        }
    });

    // Validación del formulario antes de enviar
    document.getElementById('csv-form').addEventListener('submit', function(e) {
        const archivo = document.getElementById('archivo_csv').files[0];

        let errores = [];

        if (!archivo) {
            errores.push('Debes seleccionar un archivo CSV');
        } else {
            // Validar extensión
            const extension = archivo.name.split('.').pop().toLowerCase();
            if (extension !== 'csv') {
                errores.push('El archivo debe ser un CSV (extensión .csv)');
            }

            // Validar tamaño (5MB)
            const maxSize = 5 * 1024 * 1024;
            if (archivo.size > maxSize) {
                errores.push('El archivo no puede ser mayor a 5MB');
            }
        }

        if (errores.length > 0) {
            e.preventDefault();
            alert('Por favor, corrige los siguientes errores:\n\n' + errores.join('\n'));
            return false;
        }
    });
});
</script>
{% endblock %}
