{% extends 'base.html.twig' %}

{% block title %}Nuevo Recurso Específico{% endblock %}

{% block body %}
<div class="card">
    <div class="card-header">
        <h1>Nuevo Recurso Específico</h1>
    </div>
    <div class="card-body">
        {{ form_start(form) }}
            <input type="hidden" name="asignar_todos_alumnos" id="asignar-todos-alumnos-input" value="0">
            <div class="form-group">
                {{ form_label(form.nombre) }}
                {{ form_widget(form.nombre) }}
                {{ form_errors(form.nombre) }}
            </div>

            <div class="form-group">
                {{ form_label(form.descripcion) }}
                {{ form_widget(form.descripcion) }}
                {{ form_errors(form.descripcion) }}
            </div>

            <div class="form-group">
                {{ form_label(form.grupo) }}
                {{ form_widget(form.grupo) }}
                {{ form_help(form.grupo) }}
                {{ form_errors(form.grupo) }}
            </div>

            <div class="form-group">
                {{ form_label(form.alumnos) }}
                <div id="alumnos-container" style="max-height: 400px; overflow-y: auto; border: 1px solid #ddd; padding: 1rem; border-radius: 4px; background-color: #fafafa;">
                    <div style="margin-bottom: 1rem; padding: 0.5rem; background-color: #e3f2fd; border-radius: 4px; border-left: 4px solid var(--color-primary);">
                        <strong>💡 Consejo:</strong> Puedes seleccionar un grupo arriba para asignar automáticamente todos sus alumnos, o seleccionar alumnos individualmente.
                    </div>
                    <div style="margin-bottom: 0.75rem; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; padding-bottom: 0.75rem; border-bottom: 1px solid #e0e0e0;">
                        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 600; margin: 0; user-select: none;">
                            <input type="checkbox" id="seleccionar-todos-alumnos" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--color-primary);">
                            Seleccionar todos
                        </label>
                        <span id="alumnos-seleccionados-count" style="font-size: 0.85rem; color: #666;"></span>
                    </div>
                    <div id="alumnos-list">
                        {{ form_widget(form.alumnos) }}
                    </div>
                </div>
                {{ form_errors(form.alumnos) }}
                {{ form_help(form.alumnos) }}
            </div>
            
            <style>
                /* Estilos mejorados para los checkboxes de alumnos */
                #{{ form.alumnos.vars.id }} {
                    display: grid;
                    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
                    gap: 0.75rem;
                }
                
                #{{ form.alumnos.vars.id }} > div {
                    display: flex;
                    align-items: center;
                    padding: 0.5rem;
                    background-color: #fff;
                    border: 1px solid #e0e0e0;
                    border-radius: 4px;
                    transition: all 0.2s ease;
                }
                
                #{{ form.alumnos.vars.id }} > div:hover {
                    background-color: #f5f5f5;
                    border-color: var(--color-primary);
                    box-shadow: 0 2px 4px rgba(0, 113, 181, 0.1);
                }
                
                #{{ form.alumnos.vars.id }} > div input[type="checkbox"]:checked ~ label {
                    color: var(--color-primary);
                    font-weight: 600;
                }
                
                #{{ form.alumnos.vars.id }} > div input[type="checkbox"]:checked {
                    accent-color: var(--color-primary);
                }
                
                #{{ form.alumnos.vars.id }} label {
                    display: inline-block;
                    margin-left: 0.5rem;
                    margin-bottom: 0;
                    font-weight: normal;
                    cursor: pointer;
                    flex: 1;
                    user-select: none;
                }
                
                #{{ form.alumnos.vars.id }} input[type="checkbox"] {
                    margin-right: 0;
                    vertical-align: middle;
                    cursor: pointer;
                    width: 18px;
                    height: 18px;
                }
                
                @media (max-width: 768px) {
                    #{{ form.alumnos.vars.id }} {
                        grid-template-columns: 1fr;
                    }
                }
            </style>
            
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    const seleccionarTodos = document.getElementById('seleccionar-todos-alumnos');
                    const alumnosList = document.getElementById('alumnos-list');
                    const contador = document.getElementById('alumnos-seleccionados-count');

                    function getCheckboxesAlumnos() {
                        return alumnosList.querySelectorAll('input[type="checkbox"]');
                    }

                    function actualizarContadorSeleccion() {
                        const checkboxes = getCheckboxesAlumnos();
                        const seleccionados = Array.from(checkboxes).filter(cb => cb.checked).length;
                        const total = checkboxes.length;

                        if (contador) {
                            contador.textContent = total > 0
                                ? seleccionados + ' de ' + total + ' seleccionados'
                                : '';
                        }

                        if (seleccionarTodos) {
                            seleccionarTodos.checked = total > 0 && seleccionados === total;
                            seleccionarTodos.indeterminate = seleccionados > 0 && seleccionados < total;
                        }
                    }

                    if (seleccionarTodos) {
                        seleccionarTodos.addEventListener('change', function() {
                            getCheckboxesAlumnos().forEach(function(checkbox) {
                                checkbox.checked = seleccionarTodos.checked;
                            });
                            actualizarContadorSeleccion();
                        });
                    }

                    getCheckboxesAlumnos().forEach(function(checkbox) {
                        checkbox.addEventListener('change', actualizarContadorSeleccion);
                    });

                    actualizarContadorSeleccion();

                    const formRecurso = document.getElementById('alumnos-container')?.closest('form');
                    if (formRecurso) {
                        formRecurso.addEventListener('submit', function() {
                            const checkboxes = getCheckboxesAlumnos();
                            const todosMarcados = checkboxes.length > 0
                                && Array.from(checkboxes).every(function(cb) { return cb.checked; });

                            if (todosMarcados) {
                                const inputTodos = document.getElementById('asignar-todos-alumnos-input');
                                if (inputTodos) {
                                    inputTodos.value = '1';
                                }
                                checkboxes.forEach(function(cb) {
                                    cb.disabled = true;
                                });
                            }
                        });
                    }

                    // Actualizar alumnos cuando se selecciona un grupo
                    document.getElementById('grupo-select').addEventListener('change', function() {
                    const grupoId = this.value;
                    const alumnosContainer = document.getElementById('alumnos-list');
                    const checkboxes = alumnosContainer.querySelectorAll('input[type="checkbox"]');
                    
                    if (grupoId && grupoId !== '') {
                        // Obtener alumnos del grupo mediante AJAX
                        fetch('{{ path('app_grupo_show', {'id': '__GRUPO_ID__'}) }}'.replace('__GRUPO_ID__', grupoId))
                            .then(response => response.text())
                            .then(html => {
                                // Parsear HTML para obtener IDs de alumnos
                                const parser = new DOMParser();
                                const doc = parser.parseFromString(html, 'text/html');
                                const alumnosIds = [];
                                // Buscar en la tabla de alumnos del grupo
                                const rows = doc.querySelectorAll('table tbody tr');
                                rows.forEach(row => {
                                    const firstCell = row.querySelector('td');
                                    if (firstCell) {
                                        alumnosIds.push(firstCell.textContent.trim());
                                    }
                                });
                                
                                // Marcar checkboxes de alumnos del grupo
                                checkboxes.forEach(checkbox => {
                                    const alumnoId = checkbox.value;
                                    // Verificar si el alumno está en el grupo
                                    // Nota: Esto requiere que el value del checkbox sea el ID del alumno
                                    // Por ahora, simplemente desmarcamos todos y luego el usuario puede seleccionar manualmente
                                });
                            })
                            .catch(error => {
                                console.error('Error al cargar grupo:', error);
                            });
                    }
                    });
                });
            </script>

            {% include 'recurso_especifico/_form_contenido.html.twig' %}

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Crear Recurso</button>
                <a href="{{ path('app_recurso_especifico_index') }}" class="btn btn-secondary">Cancelar</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}








