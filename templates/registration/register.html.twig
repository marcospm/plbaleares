{% extends 'base.html.twig' %}

{% block title %}Solicitar cuenta - BISPOL Aula Virtual{% endblock %}

{% block body %}
<div style="max-width: 600px; margin: 2rem auto;">
    <div class="card">
        <div class="card-header">
            <h1>Solicitar cuenta</h1>
        </div>
        <div class="card-body">
            <p style="margin-bottom: 2rem; color: var(--color-text-light);">
                Rellena el formulario y nos pondremos en contacto contigo para informarte sobre la oposición y el acceso a la plataforma.
            </p>

            {{ form_start(registrationForm) }}
                <div class="form-group">
                    {{ form_row(registrationForm.nombre) }}
                </div>
                <div class="form-group">
                    {{ form_row(registrationForm.email) }}
                </div>
                <div class="form-group">
                    {{ form_row(registrationForm.telefono) }}
                </div>
                <div class="form-group">
                    {{ form_row(registrationForm.mensaje) }}
                </div>

                <div class="alert alert-info" style="margin-top: 1rem;">
                    <strong>Nota:</strong> No se crea ninguna cuenta automáticamente. Revisaremos tu solicitud y te contactaremos por email o teléfono.
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Enviar solicitud</button>
                    <a href="{{ path('app_home') }}" class="btn btn-secondary">Cancelar</a>
                </div>
            {{ form_end(registrationForm) }}
        </div>
    </div>
</div>
{% endblock %}
