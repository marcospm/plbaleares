{% extends 'base.html.twig' %}

{% block title %}Previsualizar Preguntas CSV{% endblock %}

{% block body %}
<div class="card">
    <div class="card-header">
        <h1>Previsualizar Preguntas CSV</h1>
    </div>
    <div class="card-body">
        <div class="alert alert-info mb-4">
            <h5>Información de las preguntas:</h5>
            <ul class="mb-0">
                <li><strong>Municipio:</strong> {{ municipio.nombre }}</li>
                <li><strong>Tema Municipal:</strong> {{ temaMunicipal.nombre }}</li>
                <li><strong>Dificultad:</strong> 
                    {% if dificultad == 'facil' %}Fácil
                    {% elseif dificultad == 'moderada' %}Moderada
                    {% elseif dificultad == 'dificil' %}Difícil
                    {% else %}Indeterminado
                    {% endif %}
                </li>
                <li><strong>Total de preguntas:</strong> {{ total }}</li>
                <li>
                    <strong>Nuevas:</strong> 
                    {% set nuevas = preguntas|filter(p => not p.id)|length %}
                    {{ nuevas }}
                </li>
                <li>
                    <strong>Actualizaciones:</strong> 
                    {% set actualizaciones = preguntas|filter(p => p.id)|length %}
                    {{ actualizaciones }}
                </li>
            </ul>
        </div>

        <div class="mb-4">
            <h4>Preguntas a crear:</h4>
            <div style="max-height: 500px; overflow-y: auto; border: 1px solid #ddd; border-radius: 4px; padding: 1rem;">
                {% for pregunta in preguntas %}
                    <div class="card mb-3" style="border-left: 4px solid {% if pregunta.id %}var(--color-warning){% else %}var(--color-primary){% endif %};">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="mb-0">
                                    {% if pregunta.id %}
                                        <span class="badge badge-warning" style="background-color: var(--color-warning); color: white; margin-right: 0.5rem;">ACTUALIZAR</span>
                                        Pregunta #{{ loop.index }} (ID: {{ pregunta.id }})
                                    {% else %}
                                        Pregunta #{{ loop.index }} (NUEVA)
                                    {% endif %}
                                </h6>
                                <small class="text-muted">Línea {{ pregunta.linea }}</small>
                            </div>
                            <p class="mb-2"><strong>Texto:</strong> {{ pregunta.texto }}</p>
                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <small><strong>A)</strong> {{ pregunta.opcionA }}</small>
                                </div>
                                <div class="col-md-6">
                                    <small><strong>B)</strong> {{ pregunta.opcionB }}</small>
                                </div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <small><strong>C)</strong> {{ pregunta.opcionC }}</small>
                                </div>
                                <div class="col-md-6">
                                    <small><strong>D)</strong> {{ pregunta.opcionD }}</small>
                                </div>
                            </div>
                            <p class="mb-1">
                                <strong>Respuesta correcta:</strong> 
                                <span class="badge badge-success" style="background-color: var(--color-success); color: white;">
                                    {{ pregunta.respuestaCorrecta }}
                                </span>
                            </p>
                            {% if pregunta.retroalimentacion %}
                                <p class="mb-0">
                                    <strong>Retroalimentación:</strong> 
                                    <small>{{ pregunta.retroalimentacion }}</small>
                                </p>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>

        <form method="post" action="{{ path('app_pregunta_municipal_confirmar_crear_csv') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('confirmar_csv_municipal') }}">
            <div class="d-flex gap-2">
                {% set nuevas = preguntas|filter(p => not p.id)|length %}
                {% set actualizaciones = preguntas|filter(p => p.id)|length %}
                <button type="submit" class="btn btn-success">
                    Confirmar y Procesar {{ total }} Preguntas
                    {% if nuevas > 0 and actualizaciones > 0 %}
                        ({{ nuevas }} nuevas, {{ actualizaciones }} actualizaciones)
                    {% elseif nuevas > 0 %}
                        ({{ nuevas }} nuevas)
                    {% elseif actualizaciones > 0 %}
                        ({{ actualizaciones }} actualizaciones)
                    {% endif %}
                </button>
                <a href="{{ path('app_pregunta_municipal_new_csv') }}" class="btn btn-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
