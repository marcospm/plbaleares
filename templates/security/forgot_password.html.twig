{% extends 'base.html.twig' %}

{% block title %}Recuperar contrasena{% endblock %}

{% block body %}
<div style="max-width: 520px; margin: 3rem auto;">
    <div class="card">
        <div class="card-header">
            <h1>Recuperar contrasena</h1>
        </div>
        <div class="card-body">
            <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
                Introduce tu correo y te enviaremos un enlace para cambiar tu contrasena.
            </p>

            {{ form_start(form) }}
                <div class="form-group">
                    {{ form_label(form.email, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.email) }}
                    {{ form_errors(form.email) }}
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary" type="submit" style="flex: 1;" id="forgot-password-submit">Enviar enlace</button>
                    <a href="{{ path('app_login') }}" class="btn btn-secondary">Volver</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.getElementById('forgot-password-submit')?.addEventListener('click', function (event) {
            const form = this.closest('form');
            if (!form || form.dataset.submitted === '1') {
                event.preventDefault();
                return;
            }
            form.dataset.submitted = '1';
            this.disabled = true;
            this.textContent = 'Enviando...';
        });
    </script>
{% endblock %}
