            {% else %}
            const modoEstudioActivo = false;
            {% endif %}
            
            
            // Variables del temporizador
            let tiempoInicio = null;
            let tiempoLimite = null; // En segundos (tiempo restante o tiempo límite completo)
            let tiempoLimiteOriginal = null; // Tiempo límite original del examen (en segundos) - usado para comparación con localStorage
            let tiempoPausado = 0; // Tiempo acumulado en pausa
            let tiempoUltimaPausa = null; // Timestamp de cuando se pausó
            let intervalo = null;
            let estaPausado = false;
            
            // Obtener tiempo límite de la configuración (en minutos, convertir a segundos)
            // Obtener tiempo límite o tiempo restante del borrador
            const tiempoRestanteBorrador = {{ (config.tiempo_restante ?? null)|default('null') }};
            const tiempoLimiteMinutos = {{ (config.tiempo_limite ?? 60)|default(60) }};
            
            // Generar un identificador único del examen basado en los IDs de las preguntas
            // Esto permite que cada examen tenga su propio temporizador
            const preguntasIds = {{ preguntasIds|json_encode|raw }};
            // Crear una copia del array antes de ordenar para no mutar el original
            const preguntasIdsOrdenadas = [...preguntasIds].sort((a, b) => a - b);
            const examenId = preguntasIdsOrdenadas.join(',') + '_' + (tiempoLimiteMinutos || 60);
            
            // Verificar inmediatamente qué hay en localStorage ANTES de inicializar
            const examenIdAntes = localStorage.getItem('examen_id');
            const tiempoInicioAntes = localStorage.getItem('examen_tiempo_inicio');
            console.log('🔍 Estado ANTES de inicializar temporizador:', {
                examenIdActual: examenId,
                examenIdEnStorage: examenIdAntes,
                tiempoInicioEnStorage: tiempoInicioAntes,
                todasLasClaves: Object.keys(localStorage).filter(k => k.startsWith('examen_')),
                preguntasIdsOriginales: preguntasIds,
                preguntasIdsOrdenadas: preguntasIdsOrdenadas,
                tiempoLimiteMinutos: tiempoLimiteMinutos
            });
            
            console.log('Generando ID del examen:', {
                preguntasIdsOriginales: preguntasIds,
                preguntasIdsOrdenadas: preguntasIdsOrdenadas,
                tiempoLimiteMinutos: tiempoLimiteMinutos,
                examenId: examenId
            });
            
            // Validar que tiempoLimiteMinutos sea un número válido y positivo
            const tiempoLimiteMinutosValidado = (typeof tiempoLimiteMinutos === 'number' && tiempoLimiteMinutos > 0) 
                ? tiempoLimiteMinutos 
                : 60;
            
            // Siempre establecer el tiempo límite original (en segundos) para comparación con localStorage
            tiempoLimiteOriginal = tiempoLimiteMinutosValidado * 60;
            
            if (tiempoRestanteBorrador !== null && tiempoRestanteBorrador > 0) {
                // Si hay tiempo restante del borrador, usarlo como tiempo límite efectivo
                tiempoLimite = tiempoRestanteBorrador;
            } else {
                // Si no, usar el tiempo límite configurado (convertir minutos a segundos)
                tiempoLimite = tiempoLimiteOriginal;
            }
            
            // Validar que tiempoLimite sea un número válido y positivo
            if (!tiempoLimite || tiempoLimite <= 0 || !isFinite(tiempoLimite)) {
                console.error('Error: tiempoLimite inválido:', tiempoLimite, 'tiempoLimiteMinutos:', tiempoLimiteMinutos);
                tiempoLimite = 60 * 60; // Fallback a 60 minutos en segundos
                tiempoLimiteOriginal = tiempoLimite;
            }
            
            // Validar que tiempoLimiteOriginal sea válido
            if (!tiempoLimiteOriginal || tiempoLimiteOriginal <= 0 || !isFinite(tiempoLimiteOriginal)) {
                tiempoLimiteOriginal = 60 * 60; // Fallback a 60 minutos en segundos
            }
            
                console.log('Temporizador inicializado:', {
                tiempoLimiteMinutos: tiempoLimiteMinutos,
                tiempoLimiteMinutosValidado: tiempoLimiteMinutosValidado,
                tiempoLimiteSegundos: tiempoLimite,
                tiempoLimiteOriginalSegundos: tiempoLimiteOriginal,
                tiempoRestanteBorrador: tiempoRestanteBorrador,
                tiempoLimiteStorage: localStorage.getItem('examen_tiempo_limite'),
                tiempoInicioStorage: localStorage.getItem('examen_tiempo_inicio')
            });
            
            // Función para formatear el tiempo
            function formatearTiempo(segundos) {
                const horas = Math.floor(segundos / 3600);
                const minutos = Math.floor((segundos % 3600) / 60);
                const segs = segundos % 60;
                
                if (horas > 0) {
                    return `${horas}:${String(minutos).padStart(2, '0')}:${String(segs).padStart(2, '0')}`;
                }
                return `${String(minutos).padStart(2, '0')}:${String(segs).padStart(2, '0')}`;
            }
            
            // Función para actualizar el temporizador
            function actualizarTemporizador() {
                // Usar tiempoLimiteOriginal para el cálculo, no tiempoLimite (que puede ser tiempo restante del borrador)
                if (!tiempoInicio || !tiempoLimiteOriginal || estaPausado) return;
                
                const ahora = Date.now();
                const tiempoTranscurrido = Math.floor((ahora - tiempoInicio - tiempoPausado) / 1000);
                // Calcular tiempo restante usando el tiempo límite original
                const tiempoRestante = Math.max(0, tiempoLimiteOriginal - tiempoTranscurrido);
                
                const timerDisplay = document.getElementById('timer-display');
                if (timerDisplay) {
                    timerDisplay.textContent = formatearTiempo(tiempoRestante);
                    
                    // Cambiar color cuando quedan menos de 5 minutos
                    const timerContainer = document.getElementById('examen-timer');
                    if (timerContainer) {
                        if (tiempoRestante <= 300 && tiempoRestante > 0) {
                            timerContainer.style.background = 'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)';
                            timerContainer.style.animation = tiempoRestante <= 60 ? 'pulse 1s infinite' : 'none';
                        } else if (tiempoRestante === 0) {
                            timerContainer.style.background = 'linear-gradient(135deg, #ff0000 0%, #cc0000 100%)';
                            // Finalizar examen automáticamente
                            finalizarExamenPorTiempo();
                        } else {
                            timerContainer.style.background = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
                            timerContainer.style.animation = 'none';
                        }
                    }
                }
            }
            
            // Función para finalizar examen por tiempo
            function finalizarExamenPorTiempo() {
                if (intervalo) {
                    clearInterval(intervalo);
                    intervalo = null;
                }
                
                // Mostrar alerta y luego finalizar automáticamente
                alert('⏱️ Se ha agotado el tiempo del examen. El examen se finalizará automáticamente.');
                const formPregunta = document.getElementById('formPregunta');
                if (formPregunta) {
                    const inputFinalizar = document.createElement('input');
                    inputFinalizar.type = 'hidden';
                    inputFinalizar.name = 'accion';
                    inputFinalizar.value = 'finalizar';
                    formPregunta.appendChild(inputFinalizar);
                    formPregunta.submit();
                }
            }
            
            // Función para pausar/reanudar
            function togglePausa() {
                const btnPausa = document.getElementById('timer-pause-btn');
                const timerDisplay = document.getElementById('timer-display');
                
                if (!btnPausa) {
                    console.error('No se encontró el botón timer-pause-btn en togglePausa');
                    return;
                }
                
                if (estaPausado) {
                    // Reanudar
                    if (tiempoUltimaPausa) {
                        const tiempoEnPausa = Date.now() - tiempoUltimaPausa;
                        tiempoPausado += tiempoEnPausa;
                        tiempoUltimaPausa = null;
                        localStorage.setItem('examen_tiempo_pausado_total', tiempoPausado.toString());
                    }
                    estaPausado = false;
                    btnPausa.textContent = '⏸️ Pausar';
                    btnPausa.style.background = '#6c757d';
                    btnPausa.title = 'Pausar temporizador';
                    if (timerDisplay) {
                        timerDisplay.style.opacity = '1';
                    }
                    // Guardar estado en localStorage
                    localStorage.setItem('examen_timer_pausado', 'false');
                    localStorage.removeItem('examen_timer_ultima_pausa');
                } else {
                    // Pausar
                    tiempoUltimaPausa = Date.now();
                    estaPausado = true;
                    btnPausa.textContent = '▶️ Reanudar';
                    btnPausa.style.background = '#28a745';
                    btnPausa.title = 'Reanudar temporizador';
                    if (timerDisplay) {
                        timerDisplay.style.opacity = '0.6';
                    }
                    // Guardar estado en localStorage
                    localStorage.setItem('examen_timer_pausado', 'true');
                    localStorage.setItem('examen_timer_ultima_pausa', tiempoUltimaPausa.toString());
                }
                
                // Actualizar el temporizador inmediatamente
                actualizarTemporizador();
            }
            
            // Variable para prevenir múltiples inicializaciones
            let temporizadorInicializado = false;
            
            // Inicializar temporizador
            function inicializarTemporizador() {
                // Prevenir múltiples inicializaciones
                if (temporizadorInicializado) {
                    console.log('Temporizador ya inicializado, omitiendo...');
                    return;
                }
                
                // Limpiar intervalo anterior si existe
                if (intervalo) {
                    clearInterval(intervalo);
                    intervalo = null;
                }
                
                // Obtener tiempo de inicio desde localStorage o desde la sesión del servidor
                // Usar el identificador único del examen para las claves del localStorage
                // Leer todos los valores de localStorage de una vez con manejo de errores
                let examenIdStorage, tiempoInicioStorage, tiempoLimiteStorage, tiempoPausadoStorage, estaPausadoStorage, ultimaPausaStorage;
                
                // Obtener tiempo de inicio desde la sesión del servidor (más confiable que localStorage)
                const tiempoInicioSesion = {{ (tiempoInicioSesion ?? null)|default('null') }};
                
                try {
                    examenIdStorage = localStorage.getItem('examen_id');
                    tiempoInicioStorage = localStorage.getItem('examen_tiempo_inicio');
                    tiempoLimiteStorage = localStorage.getItem('examen_tiempo_limite');
                    tiempoPausadoStorage = localStorage.getItem('examen_tiempo_pausado_total');
                    estaPausadoStorage = localStorage.getItem('examen_timer_pausado');
                    ultimaPausaStorage = localStorage.getItem('examen_timer_ultima_pausa');
                    
                    // PRIORIDAD: Si hay tiempo de inicio en la sesión del servidor, usarlo como fuente de verdad
                    // Esto es más confiable que localStorage que puede limpiarse
                    if (tiempoInicioSesion !== null) {
                        const tiempoInicioSesionMs = tiempoInicioSesion * 1000;
                        
                        // Si no hay tiempo de inicio en localStorage o difiere significativamente, usar el de la sesión
                        if (!tiempoInicioStorage || (tiempoInicioStorage && Math.abs(tiempoInicioSesionMs - parseInt(tiempoInicioStorage, 10)) > 5000)) {
                            console.log('✅ Usando tiempo de inicio de la sesión del servidor (más confiable)');
                            tiempoInicioStorage = tiempoInicioSesionMs.toString();
                            // Guardar en localStorage para futuras referencias
                            localStorage.setItem('examen_tiempo_inicio', tiempoInicioStorage);
                            
                            // También asegurar que el examenId y tiempo límite estén guardados
                            if (!examenIdStorage || examenIdStorage !== examenId) {
                                console.log('✅ Restaurando examenId desde configuración');
                                localStorage.setItem('examen_id', examenId);
                                localStorage.setItem('examen_tiempo_limite', tiempoLimiteOriginal.toString());
                                examenIdStorage = examenId;
                                tiempoLimiteStorage = tiempoLimiteOriginal.toString();
                            }
                        }
                    }
                    
                    // Debug: mostrar todas las claves relacionadas con examen
                    const todasLasClaves = Object.keys(localStorage).filter(k => k.startsWith('examen_'));
                    console.log('📖 Leyendo de localStorage:', {
                        examenIdStorage: examenIdStorage,
                        tiempoInicioStorage: tiempoInicioStorage,
                        tiempoInicioSesion: tiempoInicioSesion,
                        tiempoLimiteStorage: tiempoLimiteStorage,
                        todasLasClavesExamen: todasLasClaves,
                        examenIdActual: examenId
                    });
                } catch (e) {
                    console.error('❌ Error al leer localStorage:', e);
                    examenIdStorage = null;
                    tiempoInicioStorage = tiempoInicioSesion !== null ? (tiempoInicioSesion * 1000).toString() : null;
                    tiempoLimiteStorage = null;
                    tiempoPausadoStorage = null;
                    estaPausadoStorage = null;
                    ultimaPausaStorage = null;
                }
                
                // Verificar si es el mismo examen (mismo ID) y si el tiempo límite coincide
                // Si no coincide el ID del examen, es un examen nuevo y debemos reiniciar
                const esMismoExamen = examenIdStorage !== null && examenIdStorage === examenId;
                
                // Verificar si el tiempo límite del localStorage coincide con el tiempo límite ORIGINAL
                // IMPORTANTE: Usar tiempoLimiteOriginal para la comparación, no tiempoLimite (que puede ser el tiempo restante)
                const tiempoLimiteStorageNum = tiempoLimiteStorage ? parseInt(tiempoLimiteStorage, 10) : null;
                // Usar comparación estricta numérica para evitar problemas de tipos
                const tiempoLimiteCoincide = tiempoLimiteStorageNum !== null && tiempoLimiteStorageNum === tiempoLimiteOriginal;
                
                // Verificar si el tiempo de inicio es reciente (menos de 24 horas)
                let tiempoInicioEsReciente = false;
                if (tiempoInicioStorage) {
                    const tiempoInicioTemp = parseInt(tiempoInicioStorage, 10);
                    const ahora = Date.now();
                    const horasTranscurridas = (ahora - tiempoInicioTemp) / (1000 * 60 * 60);
                    tiempoInicioEsReciente = horasTranscurridas < 24;
                }
                
                console.log('Verificación de coincidencia de examen y tiempo límite:', {
                    examenIdActual: examenId,
                    examenIdStorage: examenIdStorage,
                    esMismoExamen: esMismoExamen,
                    tiempoLimiteStorage: tiempoLimiteStorage,
                    tiempoLimiteStorageNum: tiempoLimiteStorageNum,
                    tiempoLimiteOriginal: tiempoLimiteOriginal,
                    tiempoLimiteCoincide: tiempoLimiteCoincide,
                    tieneTiempoInicio: !!tiempoInicioStorage,
                    tiempoInicioEsReciente: tiempoInicioEsReciente,
                    comparacionExacta: examenIdStorage === examenId,
                    tipoExamenIdActual: typeof examenId,
                    tipoExamenIdStorage: typeof examenIdStorage
                });
                
                // Verificar si hay un tiempo de inicio válido y si el tiempo transcurrido es razonable
                let debeReiniciar = false;
                // Solo verificar el tiempo transcurrido si es el mismo examen y el tiempo límite coincide
                if (esMismoExamen && tiempoInicioStorage && tiempoLimiteCoincide && tiempoInicioEsReciente) {
                    // Calcular tiempo transcurrido para verificar si es válido
                    const tiempoInicioTemp = parseInt(tiempoInicioStorage);
                    const tiempoPausadoTemp = tiempoPausadoStorage ? parseInt(tiempoPausadoStorage) : 0;
                    const ahora = Date.now();
                    const tiempoTranscurridoTemp = Math.floor((ahora - tiempoInicioTemp - tiempoPausadoTemp) / 1000);
                    
                    // Si el tiempo transcurrido es mayor que el tiempo límite ORIGINAL, es un examen nuevo
                    // También verificamos que el tiempo transcurrido no sea negativo (error de cálculo)
                    // IMPORTANTE: Usar tiempoLimiteOriginal, no tiempoLimite (que puede ser tiempo restante)
                    if (tiempoTranscurridoTemp >= tiempoLimiteOriginal || tiempoTranscurridoTemp < 0) {
                        debeReiniciar = true;
                        console.log('Tiempo transcurrido inválido o agotado. Reiniciando examen:', {
                            tiempoTranscurrido: tiempoTranscurridoTemp,
                            tiempoLimiteOriginal: tiempoLimiteOriginal,
                            tiempoLimiteEfectivo: tiempoLimite
                        });
                    }
                }
                
                // Si no es el mismo examen, no hay tiempo de inicio, el tiempo límite no coincide, el tiempo de inicio no es reciente, o el tiempo transcurrido es inválido, iniciar nuevo examen
                if (!esMismoExamen || !tiempoInicioStorage || !tiempoLimiteCoincide || !tiempoInicioEsReciente || debeReiniciar) {
                    console.log('Condición de reinicio detectada:', {
                        noEsMismoExamen: !esMismoExamen,
                        noTiempoInicio: !tiempoInicioStorage,
                        tiempoLimiteNoCoincide: !tiempoLimiteCoincide,
                        tiempoInicioNoReciente: !tiempoInicioEsReciente,
                        debeReiniciar: debeReiniciar
                    });
                    
                    // Nuevo examen o tiempo límite diferente: limpiar localStorage y establecer tiempo de inicio
                    localStorage.removeItem('examen_id');
                    localStorage.removeItem('examen_tiempo_inicio');
                    localStorage.removeItem('examen_tiempo_limite');
                    localStorage.removeItem('examen_tiempo_pausado_total');
                    localStorage.removeItem('examen_timer_pausado');
                    localStorage.removeItem('examen_timer_ultima_pausa');
                    
                    // Si viene de un borrador con tiempo restante, ajustar tiempoInicio para reflejar el tiempo ya transcurrido
                    if (tiempoRestanteBorrador !== null && tiempoRestanteBorrador > 0 && tiempoRestanteBorrador < tiempoLimiteOriginal) {
                        // Calcular cuánto tiempo ha transcurrido
                        const tiempoTranscurridoDesdeInicio = tiempoLimiteOriginal - tiempoRestanteBorrador;
                        // Ajustar tiempoInicio para que el cálculo resulte en el tiempo restante correcto
                        tiempoInicio = Date.now() - (tiempoTranscurridoDesdeInicio * 1000);
                        console.log('Iniciando desde borrador. Tiempo transcurrido:', tiempoTranscurridoDesdeInicio, 'segundos. Tiempo restante:', tiempoRestanteBorrador, 'segundos');
                    } else {
                        // Nuevo examen sin borrador: empezar desde ahora
                        tiempoInicio = Date.now();
                        console.log('Iniciando nuevo examen sin borrador. Tiempo de inicio:', new Date(tiempoInicio).toISOString());
                    }
                    
                    tiempoPausado = 0;
                    estaPausado = false;
                    tiempoUltimaPausa = null;
                    
                    // Guardar el identificador del examen y el tiempo límite ORIGINAL en localStorage para futuras comparaciones
                    // Guardar de forma síncrona y verificar inmediatamente
                    try {
                        localStorage.setItem('examen_id', examenId);
                        localStorage.setItem('examen_tiempo_inicio', tiempoInicio.toString());
                        localStorage.setItem('examen_tiempo_limite', tiempoLimiteOriginal.toString());
                        localStorage.setItem('examen_tiempo_pausado_total', '0');
                        localStorage.setItem('examen_timer_pausado', 'false');
                        
                        // Verificar que se guardó correctamente inmediatamente
                        const verificarId = localStorage.getItem('examen_id');
                        const verificarInicio = localStorage.getItem('examen_tiempo_inicio');
                        const todasLasClaves = Object.keys(localStorage).filter(k => k.startsWith('examen_'));
                        console.log('✅ Guardado en localStorage - Verificación inmediata:', {
                            examenIdGuardado: verificarId,
                            tiempoInicioGuardado: verificarInicio,
                            coincide: verificarId === examenId,
                            todasLasClaves: todasLasClaves
                        });
                    } catch (e) {
                        console.error('❌ Error al guardar en localStorage:', e);
                    }
                    
                    console.log('Nuevo examen iniciado. ID:', examenId, 'Tiempo límite original:', tiempoLimiteOriginal, 'segundos. Tiempo restante inicial:', tiempoLimite, 'segundos');
                } else {
                    // Continuar con el examen existente
                    console.log('✅ Continuando con el examen existente - NO se reinicia el temporizador');
                    tiempoInicio = parseInt(tiempoInicioStorage, 10);
                    tiempoPausado = tiempoPausadoStorage ? parseInt(tiempoPausadoStorage, 10) : 0;
                    estaPausado = estaPausadoStorage === 'true';
                    
                    if (estaPausado && ultimaPausaStorage) {
                        tiempoUltimaPausa = parseInt(ultimaPausaStorage, 10);
                    }
                    
                    // Verificar si el tiempo ha expirado
                    const ahora = Date.now();
                    // Si está pausado, calcular el tiempo pausado hasta ahora
                    let tiempoPausadoActual = tiempoPausado;
                    if (estaPausado && tiempoUltimaPausa) {
                        tiempoPausadoActual += (ahora - tiempoUltimaPausa);
                    }
                    const tiempoTranscurrido = Math.floor((ahora - tiempoInicio - tiempoPausadoActual) / 1000);
                    
                    // Calcular tiempo restante usando el tiempo límite original
                    const tiempoRestanteEfectivo = tiempoLimiteOriginal - tiempoTranscurrido;
                    
                    console.log('Continuando examen existente:', {
                        tiempoInicio: tiempoInicio,
                        tiempoTranscurrido: tiempoTranscurrido,
                        tiempoLimiteOriginal: tiempoLimiteOriginal,
                        tiempoRestante: tiempoRestanteEfectivo
                    });
                    
                    // Verificar contra el tiempo límite original
                    if (tiempoTranscurrido >= tiempoLimiteOriginal) {
                        console.warn('Tiempo agotado al continuar examen');
                        finalizarExamenPorTiempo();
                        return;
                    }
                }
                
                // Marcar como inicializado después de configurar todo
                temporizadorInicializado = true;
                
                // Actualizar botón de pausa
                const btnPausa = document.getElementById('timer-pause-btn');
                if (btnPausa) {
                    if (estaPausado) {
                        btnPausa.textContent = '▶️ Reanudar';
                        btnPausa.style.background = '#28a745';
                        btnPausa.title = 'Reanudar temporizador';
                    } else {
                        btnPausa.textContent = '⏸️ Pausar';
                        btnPausa.style.background = '#6c757d';
                        btnPausa.title = 'Pausar temporizador';
                    }
                }
                
                // Actualizar cada segundo
                intervalo = setInterval(function() {
                    if (!estaPausado) {
                        actualizarTemporizador();
                    } else {
                        // Si está pausado, actualizar el tiempo pausado acumulado
                        if (tiempoUltimaPausa) {
                            const tiempoEnPausa = Date.now() - tiempoUltimaPausa;
                            localStorage.setItem('examen_tiempo_pausado_total', (tiempoPausado + tiempoEnPausa).toString());
                        }
                    }
                }, 1000);
                
                actualizarTemporizador(); // Llamar inmediatamente
            }
            
            // Limpiar temporizador al finalizar examen
            function limpiarTemporizador() {
                temporizadorInicializado = false;
                if (intervalo) {
                    clearInterval(intervalo);
                    intervalo = null;
                }
                localStorage.removeItem('examen_id');
                localStorage.removeItem('examen_tiempo_inicio');
                localStorage.removeItem('examen_tiempo_limite');
                localStorage.removeItem('examen_tiempo_pausado_total');
                localStorage.removeItem('examen_timer_pausado');
                localStorage.removeItem('examen_timer_ultima_pausa');
            }
            
            // Inicializar cuando el DOM esté listo
            // Variable para prevenir múltiples inicializaciones de todo
            let todoInicializado = false;
            
            function inicializarTodo() {
                // Prevenir múltiples inicializaciones completas
                if (todoInicializado) {
                    console.log('⚠️ inicializarTodo ya ejecutado, omitiendo...');
                    return;
                }
                todoInicializado = true;
                
                // Inicializar temporizador solo una vez
                if (!temporizadorInicializado) {
                    inicializarTemporizador();
                }
                
                // Botón de pausa/reanudar
                const btnPausa = document.getElementById('timer-pause-btn');
                if (btnPausa) {
                    // Usar onclick directamente para evitar problemas con múltiples listeners
                    btnPausa.onclick = function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        e.stopImmediatePropagation();
                        console.log('Botón de pausa clickeado');
                        togglePausa();
                        return false;
                    };
                } else {
                    console.error('No se encontró el botón timer-pause-btn');
                }
                
                // Limpiar al enviar el formulario
                const formPregunta = document.getElementById('formPregunta');
                if (formPregunta) {
                    formPregunta.addEventListener('submit', function(e) {
                        const accion = document.querySelector('button[name="accion"][value="finalizar"]');
                        if (accion && accion.form === formPregunta) {
                            limpiarTemporizador();
                        }
                        
                        // Si es guardar borrador, añadir tiempo restante
                        const btnGuardar = document.getElementById('btnGuardarBorrador');
                        if (btnGuardar && btnGuardar.form === formPregunta && document.querySelector('button[name="accion"][value="guardar_borrador"]:focus')) {
                            // Calcular tiempo restante
                            const tiempoRestante = tiempoLimite - (Date.now() - tiempoInicio) / 1000 + tiempoPausado;
                            const inputTiempo = document.createElement('input');
                            inputTiempo.type = 'hidden';
                            inputTiempo.name = 'tiempo_restante';
                            inputTiempo.value = Math.max(0, Math.floor(tiempoRestante));
                            formPregunta.appendChild(inputTiempo);
                        }
                    });
                    
                    // Navegación rápida de preguntas
                    const preguntaLinks = document.querySelectorAll('.pregunta-link');
                    
                    preguntaLinks.forEach(function(link) {
                        link.addEventListener('click', function(e) {
                            e.preventDefault();
                            e.stopPropagation();
                            e.stopImmediatePropagation();
                            
                            const numeroDestino = parseInt(this.getAttribute('data-pregunta-num'));
                            const numeroActual = {{ numero }};
                            
                            // Si es la misma pregunta, no hacer nada
                            if (numeroDestino === numeroActual || isNaN(numeroDestino)) {
                                return false;
                            }
                            
                            // Guardar respuesta actual si hay alguna seleccionada
                            const respuestaSeleccionada = formPregunta.querySelector('input[name="respuesta"]:checked');
                            
                            // Eliminar cualquier input destino existente
                            const inputDestinoExistente = formPregunta.querySelector('input[name="numero_destino"]');
                            if (inputDestinoExistente) {
                                inputDestinoExistente.remove();
                            }
                            
                            // Crear un input oculto para el número destino
                            const inputDestino = document.createElement('input');
                            inputDestino.type = 'hidden';
                            inputDestino.name = 'numero_destino';
                            inputDestino.value = numeroDestino;
                            formPregunta.appendChild(inputDestino);
                            
                            // Enviar el formulario directamente
                            try {
                                formPregunta.submit();
                            } catch (error) {
                                console.error('Error al enviar el formulario:', error);
                                // Si falla el submit, redirigir directamente
                        window.location.href = '{{ path('app_examen_pregunta', {'numero': '__NUM__'}) }}'.replace('__NUM__', numeroDestino);
                            }
                            
                            return false;
                        });
                    });
                    
                    // Botón Anular Respuesta
                    const btnAnularRespuesta = document.getElementById('btnAnularRespuesta');
                    
                    // Función para manejar el clic del botón anular respuesta (sin recargar página)
                    function manejarClicAnularRespuesta(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        
                        if (!btnAnularRespuesta) return;
                        
                        // Deshabilitar el botón mientras se procesa
                        btnAnularRespuesta.disabled = true;
                        const textoOriginal = btnAnularRespuesta.innerHTML;
                        btnAnularRespuesta.innerHTML = '<span style="margin-right: 0.5rem;">⏳</span> Anulando...';
                        
                        // Deseleccionar todos los radio buttons visualmente
                        const radioButtons = formPregunta.querySelectorAll('input[name="respuesta"]');
                        radioButtons.forEach(function(radio) {
                            radio.checked = false;
                            // Remover el estilo de selección del label padre
                            const label = radio.closest('label');
                            if (label) {
                                // Restaurar el borde gris original completo (incluyendo el izquierdo)
                                label.style.background = '';
                                label.style.border = '2px solid var(--color-border)';
                                label.style.borderLeft = '2px solid var(--color-border)';
                            }
                        });
                        
                        // Ocultar el botón inmediatamente
                        const btnAnularRespuestaContainer = document.getElementById('btnAnularRespuestaContainer');
                        if (btnAnularRespuestaContainer) {
                            btnAnularRespuestaContainer.style.display = 'none';
                        }
                        
                        // Enviar petición AJAX para guardar el cambio en el servidor
                        fetch('{{ path('app_examen_anular_respuesta_ajax', {'numero': numero}) }}', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: JSON.stringify({})
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                // Actualizar el estado visual de la navegación rápida si es necesario
                                // La respuesta ya fue eliminada del servidor, solo actualizamos la UI
                                console.log('Respuesta anulada correctamente');
                            } else {
                                // Si hay error, volver a mostrar el botón y restaurar la selección
                                console.error('Error al anular respuesta:', data.error);
                                if (btnAnularRespuestaContainer) {
                                    btnAnularRespuestaContainer.style.display = 'flex';
                                }
                                btnAnularRespuesta.disabled = false;
                                btnAnularRespuesta.innerHTML = textoOriginal;
                            }
                        })
                        .catch(error => {
                            console.error('Error en la petición:', error);
                            // En caso de error, volver a mostrar el botón
                            if (btnAnularRespuestaContainer) {
                                btnAnularRespuestaContainer.style.display = 'flex';
                            }
                            btnAnularRespuesta.disabled = false;
                            btnAnularRespuesta.innerHTML = textoOriginal;
                        });
                    }
                    
                    if (btnAnularRespuesta) {
                        btnAnularRespuesta.addEventListener('click', manejarClicAnularRespuesta);
                    }
                    
                    // Agregar listeners a los radio buttons para mostrar/ocultar el botón dinámicamente
                    // Solo si NO estamos en modo estudio
                    {% if not (modoEstudio is defined and modoEstudio) %}
                    const radioButtons = formPregunta.querySelectorAll('input[name="respuesta"]');
                    const btnAnularRespuestaContainer = document.getElementById('btnAnularRespuestaContainer');
                    
                    // Función para restaurar el estado del botón a su estado normal
                    function restaurarEstadoBotonAnular() {
                        if (!btnAnularRespuesta) return;
                        
                        // Restaurar el texto original del botón
                        btnAnularRespuesta.innerHTML = '<span style="margin-right: 0.5rem;">↺</span> Anular Respuesta';
                        // Habilitar el botón
                        btnAnularRespuesta.disabled = false;
                    }
                    
                    // Función para mostrar/ocultar el botón según si hay respuesta seleccionada
                    function actualizarVisibilidadBotonAnular() {
                        if (!btnAnularRespuestaContainer) return;
                        
                        const hayRespuestaSeleccionada = Array.from(radioButtons).some(function(radio) {
                            return radio.checked;
                        });
                        
                        if (hayRespuestaSeleccionada) {
                            // Restaurar el estado del botón antes de mostrarlo
                            restaurarEstadoBotonAnular();
                            btnAnularRespuestaContainer.style.display = 'flex';
                        } else {
                            btnAnularRespuestaContainer.style.display = 'none';
                        }
                    }
                    
                    // Función para actualizar estilos de los labels cuando se selecciona/deselecciona una opción
                    function actualizarEstilosLabels() {
                        radioButtons.forEach(function(radio) {
                            const label = radio.closest('label');
                            if (!label) return;
                            
                            if (radio.checked) {
                                // Aplicar estilo de selección
                                label.style.background = '#e3f2fd';
                                label.style.border = '2px solid var(--color-primary)';
                                label.style.borderLeft = '2px solid var(--color-primary)';
                            } else {
                                // Restaurar el borde gris original completo (solo si no está en modo estudio con retroalimentación)
                                {% if not (modoEstudio is defined and modoEstudio and preguntaBloqueada is defined and preguntaBloqueada) %}
                                label.style.background = '';
                                label.style.border = '2px solid var(--color-border)';
                                label.style.borderLeft = '2px solid var(--color-border)';
                                {% endif %}
                            }
                        });
                    }
                    
                    // Agregar listener a cada radio button para mostrar el botón cuando se selecciona una opción
                    radioButtons.forEach(function(radio) {
                        radio.addEventListener('change', function() {
                            actualizarVisibilidadBotonAnular();
                            actualizarEstilosLabels();
                        });
                    });
                    
                    // Verificar estado inicial (por si hay una respuesta ya guardada al cargar la página)
                    actualizarVisibilidadBotonAnular();
                    actualizarEstilosLabels();
                    {% endif %}
                } else {
                    console.error('No se encontró el formulario formPregunta');
                }
            }
            
            // Sincronizar checkbox "Me la juego" con input hidden
            function sincronizarCheckboxRiesgo() {
                const checkbox = document.getElementById('me_la_juego') || document.getElementById('me_la_juego_municipal');
                const hidden = document.getElementById('me_la_juego_hidden');
                if (checkbox && hidden) {
                    hidden.value = checkbox.checked ? '1' : '0';
                }
            }
            
            // Inicializar cuando el DOM esté listo
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() {
                    inicializarTodo();
                    sincronizarCheckboxRiesgo();
                });
            } else {
                inicializarTodo();
                sincronizarCheckboxRiesgo();
            }
            
            // También inicializar en eventos de Turbo, pero permitir reiniciar cuando Turbo navega
            document.addEventListener('turbo:load', function() {
                // Permitir reinicializar cuando Turbo navega a nueva página
                todoInicializado = false;
                temporizadorInicializado = false;
                inicializarTodo();
            });
            document.addEventListener('turbo:frame-load', function() {
                if (document.getElementById('formPregunta')) {
                    todoInicializado = false;
                    temporizadorInicializado = false;
                    inicializarTodo();
                }
            });
        })();
        </script>
        
        <style>
